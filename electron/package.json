{
  "name": "arclight",
  "version": "1.0.0",
  "description": "ArcLight - Data Center Submittal Review Platform",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build-backend.js && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.positron.arclight",
    "productName": "ArcLight",
    "directories": {
      "output": "../dist/electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "node_modules/tree-kill/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist/backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
